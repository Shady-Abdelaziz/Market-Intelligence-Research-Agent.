# =============================================================================
# M.I.R.A. — Market Intelligence & Research Agent
# Copy to .env and fill in secrets (never commit .env)
# =============================================================================

# === LLM (OpenRouter) =========================================================
OPENROUTER_API_KEY=                            # REQUIRED — https://openrouter.ai/keys
LLM_PRIMARY_MODEL=x-ai/grok-4.3
LLM_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_REQUEST_TIMEOUT_SECONDS=120
LLM_PROMPT_CACHE_ENABLED=true

# === External data APIs =======================================================
NEWSAPI_KEY=                                   # REQUIRED — https://newsapi.org
MARKETAUX_KEY=                                 # REQUIRED — https://www.marketaux.com
ALPHAVANTAGE_KEY=                              # optional secondary
FINNHUB_KEY=                                   # optional fallback
EDGAR_USER_AGENT="MIRA Agent contact@example.com"  # REQUIRED by SEC EDGAR policy

# === Database =================================================================
# Default (compose Postgres):
DATABASE_URL=postgresql+asyncpg://mira:mira@postgres:5432/mira
# Standalone fallback (single docker run):
# DATABASE_URL=sqlite+aiosqlite:///./mira.db

# === Redis ====================================================================
REDIS_URL=redis://redis:6379/0
# Omit REDIS_URL to disable caching + use in-process queue (standalone mode)

# === Agent budget =============================================================
MAX_TOOL_CALLS=10
MAX_REFLECTION_PASSES=2
MAX_TOKENS_PER_JOB=200000

# === Monitoring ===============================================================
MONITOR_DEFAULT_CADENCE_SECONDS=86400
MONITOR_BASELINE_WINDOW_DAYS=30
MONITOR_TRADING_CALENDAR=NYSE

# === Reflection trigger thresholds ============================================
REFLECTION_SECTOR_CORR_THRESHOLD=0.95
REFLECTION_STALE_NEWS_HOURS=72
REFLECTION_ANALYSIS_WINDOW_DAYS=90

# === Cache TTLs (seconds) =====================================================
CACHE_TTL_YFINANCE=300
CACHE_TTL_NEWS=3600
CACHE_TTL_EDGAR=86400

# === Circuit breakers =========================================================
BREAKER_FAIL_MAX=5
BREAKER_RESET_TIMEOUT_SECONDS=60

# === Rate limiting (slowapi) ==================================================
RATELIMIT_ANALYZE=10/minute
RATELIMIT_MONITOR=5/minute

# === API ======================================================================
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
LOG_LEVEL=INFO
LOG_FORMAT=json                                # json | console

# === Frontend =================================================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
